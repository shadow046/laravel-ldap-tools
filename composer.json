{
    "name": "shadow046/laravel-ldap-tools",
    "description": "LDAP login, lookup, listing, and CSV tools for Laravel 5.6+.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ideaserv",
            "email": "alerts@ideaserv.online"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ext-ldap": "*",
        "illuminate/console": ">=5.6 <13.0",
        "illuminate/support": ">=5.6 <13.0"
    },
    "autoload": {
        "psr-4": {
            "Ideaserv\\LdapTools\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ideaserv\\LdapTools\\LdapToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
